{
  "name": "megadon",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:api": "npm run dev -w @megadon/api",
    "dev:mobile": "npm run start -w mobile",
    "dev:emulators": "firebase emulators:start --only auth,firestore,storage"
  },
  "devDependencies": {
    "firebase-tools": "^13.29.1"
  }
}
