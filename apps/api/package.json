{
  "name": "@megadon/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:emulator": "firebase --project=megadon-test emulators:exec --only auth,firestore,storage 'vitest run'",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:full": "vitest run --config vitest.e2e.full.config.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@google-cloud/secret-manager": "^5.6.0",
    "@google-cloud/storage": "^7.14.0",
    "@google-cloud/tasks": "^5.5.1",
    "@megadon/types": "*",
    "@napi-rs/canvas": "^0.1.100",
    "ffmpeg-static": "^5.2.0",
    "fastify": "^5.1.0",
    "firebase-admin": "^13.0.1",
    "openai": "^4.73.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@types/node": "^22.10.1",
    "firebase": "^11.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
