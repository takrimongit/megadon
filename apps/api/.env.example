# Local dev (emulators)
NODE_ENV=development
ROLE=api
PORT=8080

GCP_PROJECT=megadon-dev
GCP_REGION=us-central1
STORAGE_BUCKET=megadon-dev.appspot.com

# Emulator hosts (set by `firebase emulators:start` or manually)
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIRESTORE_EMULATOR_HOST=localhost:8081
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199

# Cloud Tasks (production)
CLOUD_TASKS_QUEUE=ad-generation
WORKER_URL=http://localhost:8080
TASKS_INVOKER_SA=tasks-invoker@megadon-dev.iam.gserviceaccount.com

# Provider: kie.ai (OpenAI-compatible AI gateway)
KIE_API_KEY=
KIE_BASE_URL=https://api.kie.ai/v1
KIE_MODEL=gpt-4o-mini

HIGGSFIELD_API_KEY=
