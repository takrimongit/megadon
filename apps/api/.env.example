# Local dev (emulators)
NODE_ENV=development
ROLE=api
PORT=8080

GCP_PROJECT=megadon-dev
GCP_REGION=us-central1
STORAGE_BUCKET=megadon-dev.appspot.com

# Emulator hosts (set by `firebase emulators:start` or manually)
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIRESTORE_EMULATOR_HOST=localhost:8081
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199

# Cloud Tasks (production)
CLOUD_TASKS_QUEUE=ad-generation
WORKER_URL=http://localhost:8080
TASKS_INVOKER_SA=tasks-invoker@megadon-dev.iam.gserviceaccount.com

# Provider: kie.ai
# - Chat: per-model OpenAI-compatible at https://api.kie.ai/{model}/v1
# - Images: async task pattern at https://api.kie.ai/api/v1/jobs/*
KIE_API_KEY=
KIE_CHAT_MODEL=gpt-5-2
KIE_IMAGE_MODEL=flux-2/pro-text-to-image

# Meta (Facebook Page + Instagram) organic publishing.
# Put REAL values in apps/api/.env (gitignored) — never here.
META_PAGE_TOKEN=
META_FACEBOOK_PAGE_ID=
META_INSTAGRAM_USER_ID=

# HeyGen avatar video (talking spokesperson) — used when a video ad's
# videoStyle is "avatar". Put the REAL key in apps/api/.env (gitignored).
HEYGEN_API_KEY=
HEYGEN_API_BASE=https://api.heygen.com
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=
